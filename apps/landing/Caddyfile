# CinneTemple landing site. Railway injects PORT.
{
	auto_https off
	admin off
}

:{$PORT:80} {
	root * /srv
	encode gzip zstd

	# Long-cache images; HTML + CSS revalidate so deploys land immediately.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=604800"
	@pages not path /assets/*
	header @pages Cache-Control "no-cache"

	handle_errors {
		@404 expression {err.status_code} == 404
		rewrite @404 /404.html
		file_server
	}

	file_server
}
