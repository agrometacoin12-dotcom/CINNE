<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark-only app theme; Compose paints everything. Window background matches
         the iOS launch screen (#090B12) so the splash never flashes white. -->
    <style name="Theme.CinneTemple" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/launch_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
