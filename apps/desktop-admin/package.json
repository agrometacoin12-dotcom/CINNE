{
  "name": "@cinnetemple/desktop-admin",
  "productName": "CinneTemple Studio",
  "version": "1.0.0",
  "private": true,
  "description": "CinneTemple Studio \u2014 desktop admin console for the CinneTemple pay-once cinema platform.",
  "main": "dist-electron/main.cjs",
  "author": "CinneTemple",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "make-icon": "node scripts/make-icon.mjs",
    "dist:win": "npm run build && npm run make-icon && electron-builder --win"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "37.2.0",
    "electron-builder": "26.0.12",
    "esbuild": "0.24.2",
    "png-to-ico": "2.1.8",
    "typescript": "5.6.3",
    "vite": "6.3.5",
    "eslint": "^8.57.1",
    "@typescript-eslint/parser": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0"
  }
}
