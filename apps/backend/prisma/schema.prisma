// CinneTemple — Prisma schema (Phase 1: Identity & Access)
// See docs/DATABASE.md for the design rationale.

generator client {
  provider      = "prisma-client-js"
  // Bundle the engine for the container's platform (Debian + OpenSSL 3) as well
  // as the local dev machine.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AuthProvider {
  EMAIL
  APPLE
  GOOGLE
  PASSKEY
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique
  passwordHash   String?    @map("password_hash")
  cognitoSub     String?    @unique @map("cognito_sub")
  status         UserStatus @default(PENDING_VERIFICATION)
  emailVerified  Boolean    @default(false) @map("email_verified")
  mfaEnabled     Boolean    @default(false) @map("mfa_enabled")
  phoneNumberEnc Bytes?     @map("phone_number_enc")

  profile       Profile?
  sessions      Session[]
  roles         UserRole[]
  credentials   Credential[]
  auditLogs     AuditLog[]      @relation("AuditActor")
  watchlist     WatchlistItem[]
  devices       DeviceToken[]
  purchases     Purchase[]      @relation("Payer")
  giftsReceived Purchase[]      @relation("Beneficiary")
  entitlements  Entitlement[]
  chatMessages  PremiereChatMessage[]
  playbackProgress PlaybackProgress[]
  episodePlayback  EpisodePlayback[]
  desktopAuthCodes DesktopAuthCode[]

  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Profile {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @unique @map("user_id") @db.Uuid
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String  @map("display_name")
  avatarUrl   String? @map("avatar_url")
  locale      String  @default("en")
  bio         String?

  history   ProfileHistory[]
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("profiles")
}

model ProfileHistory {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  snapshot  Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([profileId])
  @@map("profile_history")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @map("refresh_token_hash")
  deviceId         String?   @map("device_id")
  userAgent        String?   @map("user_agent")
  ip               String?
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model Role {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique
  users     UserRole[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Credential {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   AuthProvider
  providerId String       @map("provider_id")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@index([userId])
  @@map("credentials")
}

/// A user's saved title. Title metadata lives in DynamoDB; this row links a user
/// to a catalogue title id (the cross-store relationship).
model WatchlistItem {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId   String    @map("title_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([userId, titleId])
  @@index([userId])
  @@map("watchlist_items")
}

enum DevicePlatform {
  IOS
  WEB
}

/// A registered device for push notifications. `endpointArn` is the SNS platform
/// endpoint created when the token is registered.
model DeviceToken {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    DevicePlatform
  token       String
  endpointArn String?        @map("endpoint_arn")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@unique([token])
  @@index([userId])
  @@map("device_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// Commerce: pay-per-view (mobile cinema). Catalogue metadata (title, price,
// premiere flags, video key) lives in the catalogue store (DynamoDB/local seed);
// money + access rights are transactional and live here in Postgres.
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentProvider {
  MOCK
  PAYSTACK
  APPLE_IAP
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum EntitlementStatus {
  ACTIVE // purchased, not yet started OR within the viewing window
  EXPIRED // viewing window elapsed
  CONSUMED // finished
  REVOKED
}

/// A single pay-per-view transaction. `userId` is the payer; `beneficiaryUserId`
/// is who gets to watch (same as payer unless it was gifted).
model Purchase {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  user              User            @relation("Payer", fields: [userId], references: [id], onDelete: Cascade)
  beneficiaryUserId String          @map("beneficiary_user_id") @db.Uuid
  beneficiary       User            @relation("Beneficiary", fields: [beneficiaryUserId], references: [id], onDelete: Cascade)
  titleId           String          @map("title_id") @db.Uuid
  titleName         String          @map("title_name")
  amountMinor       Int             @map("amount_minor") // smallest currency unit (kobo/cents)
  currency          String          @default("NGN")
  provider          PaymentProvider
  providerRef       String?         @unique @map("provider_ref")
  status            PurchaseStatus  @default(PENDING)
  isGift            Boolean         @default(false) @map("is_gift")
  entitlement       Entitlement?
  createdAt         DateTime        @default(now()) @map("created_at")
  paidAt            DateTime?       @map("paid_at")

  @@index([userId])
  @@index([beneficiaryUserId])
  @@index([titleId])
  @@index([status])
  @@map("purchases")
}

/// The right to watch a title once, for the duration of the movie. Created when a
/// purchase is paid; the viewing window opens on first play (`startedAt`).
model Entitlement {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId    String            @map("title_id") @db.Uuid
  purchaseId String            @unique @map("purchase_id") @db.Uuid
  purchase   Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  status     EntitlementStatus @default(ACTIVE)
  startedAt  DateTime?         @map("started_at")
  expiresAt  DateTime?         @map("expires_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  @@index([userId, titleId])
  @@index([status])
  @@map("entitlements")
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalogue: the persistent source of truth for titles (replaces the volatile
// in-memory/DynamoDB stores). Mirrors the Title domain entity in
// src/modules/catalogue/domain/title.entity.ts — keep the two in sync.
// ─────────────────────────────────────────────────────────────────────────────

enum TitleType {
  MOVIE
  SERIES
}

enum TitleStatus {
  DRAFT
  PUBLISHED
}

/// A catalogue title (movie or series). Array columns (genres/cast/categories)
/// are native Postgres text[]; media fields hold object keys resolved to URLs
/// by the service layer.
model CatalogueTitle {
  id              String      @id @db.Uuid
  type            TitleType
  title           String
  tagline         String?
  overview        String
  year            Int
  genres          String[]
  runtimeMinutes  Int?        @map("runtime_minutes")
  seasons         Int?
  maturityRating  String?     @map("maturity_rating")
  rating          Float       @default(0)
  posterKey       String?     @map("poster_key")
  heroKey         String?     @map("hero_key")
  cast            String[]    @map("cast_members")
  director        String?
  categories      String[]
  popularity      Int         @default(0)
  featured        Boolean     @default(false)
  status          TitleStatus @default(DRAFT)
  priceMinor      Int         @default(0) @map("price_minor")
  currency        String      @default("NGN")
  videoKey        String?     @map("video_key")
  durationSeconds Int?        @map("duration_seconds")
  isPremiere      Boolean     @default(false) @map("is_premiere")
  premiereStartAt DateTime?   @map("premiere_start_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  seasonRecords Season[]

  @@index([status])
  @@index([featured])
  @@index([popularity])
  @@index([isPremiere, status])
  @@map("catalogue_titles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Series: seasons & episodes. One ticket buys the series; EACH EPISODE is
// watchable exactly once (per-episode watch-once mirrors the movie flow).
// `CatalogueTitle.seasons` stays a derived count maintained on season
// create/delete by the admin series service.
// ─────────────────────────────────────────────────────────────────────────────

model Season {
  id       String         @id @default(uuid()) @db.Uuid
  titleId  String         @map("title_id") @db.Uuid
  title    CatalogueTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
  number   Int
  name     String?
  overview String?

  episodes  Episode[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([titleId, number])
  @@map("seasons")
}

model Episode {
  id       String @id @default(uuid()) @db.Uuid
  seasonId String @map("season_id") @db.Uuid
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  /// Denormalized series title id so playback/consumption checks avoid a join.
  titleId        String  @map("title_id") @db.Uuid
  number         Int
  name           String
  overview       String?
  runtimeMinutes Int?    @map("runtime_minutes")
  /// Playback length in seconds; defines the per-episode viewing window.
  durationSeconds Int?    @map("duration_seconds")
  /// Object key for the playable master. Resolved to a signed URL on play —
  /// never exposed to viewers directly.
  videoKey String? @map("video_key")
  /// Episode still artwork (public image, like posters).
  stillKey String? @map("still_key")

  playback  EpisodePlayback[]
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([seasonId, number])
  @@index([titleId])
  @@map("episodes")
}

/// Per-episode watch-once state (mirror of the movie flow's entitlement window
/// + PlaybackProgress, scoped to one episode). `consumedAt` is stamped at
/// >=95% progress; a consumed episode can never be streamed again.
model EpisodePlayback {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodeId       String    @map("episode_id") @db.Uuid
  episode         Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  titleId         String    @map("title_id") @db.Uuid
  positionSeconds Int       @default(0) @map("position_seconds")
  durationSeconds Int       @map("duration_seconds")
  startedAt       DateTime? @map("started_at")
  expiresAt       DateTime? @map("expires_at")
  consumedAt      DateTime? @map("consumed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([userId, episodeId])
  @@index([userId, titleId])
  @@map("episode_playback")
}

/// Single-use PKCE-style device-link code for the desktop app. Only the
/// SHA-256 of the code is stored; the challenge is base64url(SHA-256(verifier))
/// supplied by the desktop client via the web approval page.
model DesktopAuthCode {
  id         String    @id @default(uuid()) @db.Uuid
  codeHash   String    @unique @map("code_hash")
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge  String
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("desktop_auth_codes")
}

/// Resume-watching position per user per title. Endpoints land in a later
/// phase; the model ships with the catalogue persistence migration.
model PlaybackProgress {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId         String   @map("title_id") @db.Uuid
  positionSeconds Int      @map("position_seconds")
  durationSeconds Int      @map("duration_seconds")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, titleId])
  @@index([userId])
  @@map("playback_progress")
}

/// A live-chat message attached to a title's premiere.
model PremiereChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  titleId   String   @map("title_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  author    String
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([titleId, createdAt])
  @@map("premiere_chat_messages")
}
