# Serves the static Next.js export. Railway injects PORT.
{
	auto_https off
	admin off
}

:{$PORT:80} {
	root * /srv
	encode gzip zstd

	# Long-cache immutable Next build assets.
	@static path /_next/*
	header @static Cache-Control "public, max-age=31536000, immutable"

	handle_errors {
		@404 expression {err.status_code} == 404
		rewrite @404 /404.html
		file_server
	}

	file_server
}
