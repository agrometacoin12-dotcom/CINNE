# ─── Shared ─────────────────────────────────────────────────────────────────
NODE_ENV=development
STAGE=dev
AWS_REGION=us-east-1

# ─── Backend (apps/backend) ─────────────────────────────────────────────────
PORT=4000
# Local Postgres (docker-compose). In AWS this comes from Secrets Manager.
DATABASE_URL=postgresql://cinnetemple:cinnetemple@localhost:5432/cinnetemple?schema=public
REDIS_URL=redis://localhost:6379

# Amazon Cognito (created by infrastructure/cdk)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=cinnetemple-prod.auth.us-east-1.amazoncognito.com
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx

# JWT (app-issued access/refresh tokens; signing keys live in Secrets Manager)
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=https://api.cinnetemple.com
JWT_AUDIENCE=cinnetemple-clients

# SES (transactional email)
SES_FROM_ADDRESS=no-reply@cinnetemple.com

# ─── Phase 2/3 services (local defaults keep everything offline) ─────────────
CATALOGUE_DRIVER=local
SEARCH_DRIVER=local
EVENTS_DRIVER=local
PUSH_DRIVER=local
# In AWS these are set from CDK stack outputs:
# CATALOGUE_TABLE=cinnetemple-prod-catalogue
# MEDIA_BASE_URL=https://dxxxx.cloudfront.net
# OPENSEARCH_ENDPOINT=https://search-...es.amazonaws.com
# EVENT_BUS_NAME=cinnetemple
# SNS_PLATFORM_APP_ARN=arn:aws:sns:us-east-1:...:app/APNS/cinnetemple
# REALTIME_ENDPOINT=https://xxxx.execute-api.us-east-1.amazonaws.com/prod

# ─── Web (apps/web) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_COGNITO_DOMAIN=cinnetemple-dev.auth.eu-west-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
